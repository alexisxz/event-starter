# ============================================================
# Strapi CMS (sidecar running in ./cms)
# ============================================================
# Base URL where the Strapi server is reachable.
STRAPI_URL=http://localhost:1337

# Full-access API token generated in Strapi admin:
#   Settings -> API Tokens -> Create new API Token
#   Type: Full access, Duration: Unlimited
STRAPI_API_TOKEN=your-strapi-api-token

# ============================================================
# Resend
# ============================================================
# Resend API key from https://resend.com/api-keys
RESEND_API_KEY=re_your_api_key

# Sender identity. The domain must be verified in Resend for production.
# During local testing you may use "onboarding@resend.dev".
RESEND_FROM_EMAIL="Event Starter <noreply@example.de>"

# Comma-separated list of internal recipients that receive new-submission notifications.
ADMIN_NOTIFICATION_EMAILS=team@example.de,sales@example.de
